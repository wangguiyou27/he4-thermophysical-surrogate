{
  "name": "he4_single_phase_extended_2p2_phaseaware_critical_features",
  "data_path": "../data/he4data_single_phase_extended_2p2_critical_features.csv",
  "skip_rows": [],
  "input_cols": [
    "Temperature (K)",
    "Pressure (MPa)",
    "phase_code",
    "reduced_temperature",
    "reduced_pressure",
    "critical_distance",
    "inverse_critical_distance",
    "abs_reduced_temperature_offset",
    "abs_reduced_pressure_offset"
  ],
  "target_cols": [
    "Density (kg/m^3)",
    "Entropy (kJ/(kg·K))",
    "Enthalpy (kJ/kg)",
    "Speed of Sound (m/s)",
    "Cv (kJ/(kg·K))",
    "Cp (kJ/(kg·K))",
    "Viscosity (μPa·s)",
    "Thermal Conductivity (mW/(m·K))"
  ],
  "log_input_cols": [
    "Temperature (K)",
    "Pressure (MPa)",
    "critical_distance",
    "abs_reduced_temperature_offset",
    "abs_reduced_pressure_offset"
  ],
  "log_target_cols": [
    "Density (kg/m^3)",
    "Speed of Sound (m/s)",
    "Cv (kJ/(kg·K))",
    "Cp (kJ/(kg·K))",
    "Viscosity (μPa·s)",
    "Thermal Conductivity (mW/(m·K))"
  ],
  "shifted_log_target_offsets": {
