    "low_liquid_vapor": 4.5,
    "low": 2.5,
    "transition": 1.5,
    "middle": 1.0,
    "high": 1.0
  },
  "conditional_sample_weights": [
    {
      "name": "near_lambda_liquid_enthalpy",
      "bounds": {
        "Temperature (K)": [2.2, 2.45],
        "Pressure (MPa)": [0.85, 1.35],
        "phase_code": [4, 4]
      },
      "weight": 3.0
