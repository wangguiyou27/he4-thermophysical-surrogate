  ],
  "target_loss_weights": {
    "Density (kg/m^3)": 2.5,
    "Entropy (kJ/(kg·K))": 3.5,
    "Enthalpy (kJ/kg)": 4.0,
    "Speed of Sound (m/s)": 1.2,
    "Cv (kJ/(kg·K))": 1.0,
    "Cp (kJ/(kg·K))": 3.0,
    "Viscosity (μPa·s)": 1.0,
    "Thermal Conductivity (mW/(m·K))": 1.3
  }
